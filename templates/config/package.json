{
  "name": "agentic-qe-tests",
  "version": "2.0.0",
  "description": "Auto-generated test framework by Agentic QE Framework v2 (Playwright + WebdriverIO)",
  "scripts": {
    "test": "npx playwright test --project=chrome",
    "test:smoke": "npx playwright test --grep @smoke --project=chrome",
    "test:regression": "npx playwright test --grep @regression --project=chrome",
    "test:api": "npx playwright test --grep @api --project=chrome",
    "test:hybrid": "npx playwright test --grep @hybrid --project=chrome",
    "test:p0": "npx playwright test --grep @P0 --project=chrome",
    "test:p1": "npx playwright test --grep @P1 --project=chrome",
    "test:headed": "npx playwright test --project=chrome --headed",
    "test:mobile:android": "PLATFORM=android npx wdio run wdio.conf.ts --spec",
    "test:mobile:ios": "PLATFORM=ios npx wdio run wdio.conf.ts --spec",
    "typecheck": "tsc --noEmit",
    "report": "npx playwright show-report",
    "report:allure": "npx allure generate allure-results --clean -o allure-report && npx allure open allure-report",
    "report:allure:mobile": "npx allure generate allure-results --clean -o allure-report && npx allure open allure-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^22.0.0",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.7.0",
    "dotenv": "^16.4.0",
    "typescript": "^5.7.0",
    "xlsx": "^0.18.0"
  },
  "dependencies": {
    "@wdio/allure-reporter": "^9.27.0",
    "@wdio/cli": "^9.0.0",
    "@wdio/json-reporter": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "@wdio/types": "^9.0.0",
    "expect-webdriverio": "^5.0.0",
    "webdriverio": "^9.0.0"
  }
}
