{
  "testSuites": {
    "smoke": { "grep": "@smoke", "timeout": 30, "retries": 0 },
    "regression": { "grep": "@regression", "timeout": 120, "retries": 1 },
    "p0": { "grep": "@P0", "timeout": 60, "retries": 1 },
    "p1": { "grep": "@P1", "timeout": 60, "retries": 0 },
    "api": { "grep": "@api", "timeout": 30, "retries": 0 }
  },
  "sharding": { "enabled": false, "count": 4 },
  "browsers": ["chrome"],
  "failureClassification": {
    "stabilityThreshold": 0.95,
    "autoRetryMaxAttempts": 2,
    "autoFixEnabled": false,
    "autoFixMaxPerRun": 5
  },
  "defectTracking": {
    "tracker": "none",
    "deduplication": true,
    "autoCloseAfterPassCount": 5
  },
  "artifacts": { "retentionDays": 30, "nightlyRetentionDays": 90 }
}
