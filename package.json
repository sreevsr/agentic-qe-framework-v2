{
  "name": "agentic-qe-framework-v3",
  "version": "3.0.0",
  "description": "Agentic QE Framework v3 — Enterprise-grade codeless test automation via plan-based replay",
  "private": true,
  "scripts": {
    "setup": "node setup.js",
    "setup:all-browsers": "node setup.js --all-browsers",
    "validate": "node setup.js --validate-only",
    "replay": "npx tsx scripts/replay-engine.ts --",
    "replay:headed": "npx tsx scripts/replay-engine.ts --headed --",
    "replay:mobile": "npx tsx scripts/mobile-replay-engine.ts --",
    "validate-plan": "node scripts/plan-validator.js --",
    "parse-results": "node scripts/test-results-parser.js --",
    "parse-swagger": "node scripts/swagger-parser.js --",
    "classify-failures": "node scripts/failure-classifier.js --",
    "collect-metrics": "node scripts/metrics-collector.js --",
    "eval-summary": "node scripts/eval-summary.js --",
    "rehash-skills": "node scripts/rehash-skills.js",
    "ci:run": "node ci/scripts/ci-test-runner.js --"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "dotenv": "^17.3.1",
    "playwright": "^1.58.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
