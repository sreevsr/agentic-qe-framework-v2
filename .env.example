# IMPORTANT: If any value contains # or special characters, wrap it in double quotes.
# Example: TEST_PASSWORD="my#secret!pass"
# Unquoted # silently truncates the value (dotenv behavior).

# Application Under Test
BASE_URL=https://your-app-url.com
TEST_USERNAME=your-test-username
TEST_PASSWORD="your-test-password"

# SSO / OAuth (if applicable)
SSO_EMAIL=your-sso-email@company.com
SSO_PASSWORD="your-sso-password"

# API Testing
API_BASE_URL=https://your-api-url.com
API_TOKEN=your-api-token
API_USERNAME=your-api-username
API_PASSWORD="your-api-password"

# Database (future — for DB QUERY skill)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=your-database
# DB_USERNAME=your-db-username
# DB_PASSWORD="your-db-password"
