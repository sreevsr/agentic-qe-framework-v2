# IMPORTANT: If any value contains # or special characters, wrap it in double quotes.
# Example: TEST_PASSWORD="my#secret!pass"
# Unquoted # silently truncates the value (dotenv behavior).

# Application Under Test
BASE_URL=https://automationexercise.com/
TEST_USERNAME=your-test-username
TEST_PASSWORD="your-test-password"

# AutomationExercise Signup
SIGNUP_EMAIL=qademo_uniquerun@gmail.com
SIGNUP_PASSWORD="Test@12345"

# Payment Card Details
CARD_NUMBER=1234567891011234
CARD_CVC=585
CARD_EXP_MONTH=02
CARD_EXP_YEAR=2032

# SSO / OAuth (if applicable)
SSO_EMAIL=your-sso-email@company.com
SSO_PASSWORD="your-sso-password"

# API Testing
API_BASE_URL=https://your-api-url.com
API_TOKEN=your-api-token
API_USERNAME=your-api-username
API_PASSWORD="your-api-password"

# Mobile / Appium
PLATFORM=android
APPIUM_HOST=localhost
APPIUM_PORT=4723
ANDROID_DEVICE=emulator-5554
ANDROID_APP_PACKAGE=com.example.app
ANDROID_APP_ACTIVITY=com.example.app.MainActivity
APP_PATH=/path/to/app.apk
IOS_DEVICE=iPhone 15
IOS_VERSION=17.0
IOS_BUNDLE_ID=com.example.app
IOS_UDID=
NO_RESET=false

# Framework Settings
HEADLESS=true
DEFAULT_TIMEOUT=30000
NAVIGATION_TIMEOUT=60000
