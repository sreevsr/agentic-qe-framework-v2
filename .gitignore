# Dependencies
node_modules/
output/node_modules/

# Environment secrets — NEVER commit
.env
.env.local
output/**/.env
*.pem
*.key

# IDE — keep MCP config, ignore everything else
.vscode/*
!.vscode/mcp.json
!.vscode/extensions.json
.idea/

# Claude Code CLI config (developer-local)
.claude/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Playwright runtime artifacts (transient)
output/test-results/
output/screenshots/
output/playwright-report/
output/blob-report/

# Agent reports (transient — regenerated each run)
output/reports/
output/**/explorer-report-*.md
output/**/executor-report-*.md
output/**/pipeline-summary-*.md
output/**/review-scorecard-*.md
output/**/precheck-report-*.json

# Runtime artifacts
output/test-data/shared-state.json
output/test-data/shared-state.json.lock

# Executor backup files
output/**/*.backup*
output/**/*.bak*
output/**/*.broken

# Storage state (contains auth tokens — NEVER commit)
output/storage-state*.json
output/auth/

# Parsed swagger specs (generated by swagger-parser.js)
scenarios/api/**/swagger-specs/*.parsed.json

# Scout reports (generated)
output/scout-reports/

# Images (screenshots, failure captures)
*.png

# Logs and temp
*.log
*.tmp
npm-debug.log*

# Python (if future language templates used)
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/

# Backup files
*.bak
*.backup

# Skill hashes (generated by rehash-skills.js)
skills/.skill-hashes.json
