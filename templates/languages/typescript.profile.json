{
  "language": "typescript",
  "displayName": "TypeScript",
  "playwright_package": "@playwright/test",
  "test_framework": "playwright-test",
  "file_extension": ".ts",
  "spec_file_pattern": "{scenario}.spec.ts",
  "page_object_pattern": "{PageName}Page.ts",
  "locator_file_pattern": "{page-name}.locators.json",

  "naming_conventions": {
    "class": "PascalCase",
    "method": "camelCase",
    "variable": "camelCase",
    "file": "kebab-case",
    "constant": "UPPER_SNAKE_CASE"
  },

  "async_model": "async_await",
  "assertion_style": {
    "hard": "expect(locator).toHaveText(value)",
    "soft": "expect.soft(value).toBe(expected)",
    "url": "await expect(page).toHaveURL(pattern)",
    "visible": "await expect(locator).toBeVisible()",
    "count": "await expect(locator).toHaveCount(n)"
  },

  "env_access": "process.env.{VARIABLE}",
  "env_access_with_default": "process.env.{VARIABLE} || '{default}'",

  "fixture_pattern": "test('{name}', async ({ page }) => { ... })",
  "fixture_hybrid": "test('{name}', async ({ page, request }) => { ... })",
  "fixture_api": "test('{name}', async ({ request }) => { ... })",
  "beforeAll_fixture": "test.beforeAll(async ({ browser }) => { ... })",
  "beforeEach_fixture": "test.beforeEach(async ({ page }) => { ... })",

  "imports": {
    "test_framework": "import { test, expect } from '@playwright/test';",
    "page_object": "import { {ClassName} } from '../../pages/{ClassName}';",
    "test_data": "import testData from '../test-data/{type}/{scenario}.json';",
    "shared_data": "import { loadTestData } from '../../core/test-data-loader';",
    "save_state": "import { saveState } from '../core/shared-state';"
  },

  "templates_dir": {
    "core": "templates/core",
    "config": "templates/config"
  },

  "install_commands": {
    "dependencies": "npm install",
    "playwright": "npx playwright install --with-deps chromium",
    "playwright_all": "npx playwright install"
  },

  "run_commands": {
    "test": "npx playwright test {spec} --project=chrome",
    "test_grep": "npx playwright test --grep {tag} --project=chrome",
    "typecheck": "npx tsc --noEmit",
    "report": "npx playwright show-report"
  },

  "config_files": ["playwright.config.ts", "package.json", "tsconfig.json", ".env.example"],
  "core_files": ["base-page.ts", "locator-loader.ts", "test-data-loader.ts", "shared-state.ts"],

  "step_wrapper": "await test.step('{label}', async () => { {code} });",
  "capture_declaration": "let {varName}: string;",
  "capture_assignment": "{varName} = await {pageObject}.{getter}();",

  "page_object_template": {
    "class_declaration": "export class {ClassName} extends BasePage {\n  constructor(page: Page) {\n    super(page, '{locator-file}');\n  }\n}",
    "method_template": "async {methodName}({params}): Promise<{returnType}> {\n  {body}\n}",
    "base_import": "import { Page } from '@playwright/test';\nimport { BasePage } from '../core/base-page';"
  }
}
