{
  "$schema": "contracts/manifest.schema.json",
  "name": "explorer-builder",
  "version": "2.0.0",
  "protocolVersion": "1.0.0",
  "description": "Explores live application via browser, verifies every interaction, and builds production-quality Playwright test code from observed reality. Replaces Analyst + Generator + most of Healer from v1.",
  "provider": {
    "organization": "Agentic QE Framework",
    "repository": "agentic-qe-framework-v2"
  },
  "tags": ["testing", "playwright", "browser-automation", "code-generation", "enterprise-qa"],
  "coreInstructions": [
    "agents/core/explorer-builder.md",
    "agents/core/code-generation-rules.md",
    "agents/core/quality-gates.md",
    "agents/core/scenario-handling.md"
  ],
  "documentationUrl": "agents/core/explorer-builder.md",
  "input": {
    "scenario": {
      "type": "file",
      "format": "markdown",
      "mimeType": "text/markdown",
      "required": true,
      "description": "Scenario .md file with test steps"
    },
    "appContext": {
      "type": "file",
      "format": "markdown",
      "mimeType": "text/markdown",
      "required": false,
      "description": "App-context file with learned patterns for this application"
    },
    "type": {
      "type": "string",
      "enum": ["web", "api", "hybrid", "mobile", "mobile-hybrid"],
      "required": true,
      "description": "Scenario type — determines fixture, skills, and browser usage"
    },
    "folder": {
      "type": "string",
      "required": false,
      "description": "Optional subfolder for organizing output by app/feature"
    },
    "language": {
      "type": "string",
      "enum": ["typescript"],
      "default": "typescript",
      "description": "Target language (TypeScript only in v2.0)"
    }
  },
  "output": {
    "locators": {
      "type": "file[]",
      "format": "json",
      "mimeType": "application/json",
      "location": "output/locators/*.locators.json",
      "description": "Verified selector JSON files with primary + fallbacks"
    },
    "pageObjects": {
      "type": "file[]",
      "format": "typescript",
      "mimeType": "text/typescript",
      "location": "output/pages/*Page.ts",
      "description": "Page object classes with verified interaction methods"
    },
    "specFile": {
      "type": "file",
      "format": "typescript",
      "mimeType": "text/typescript",
      "location": "output/tests/{type}/[{folder}/]{scenario}.spec.ts",
      "description": "Playwright test spec with verified steps"
    },
    "testData": {
      "type": "file",
      "format": "json",
      "mimeType": "application/json",
      "location": "output/test-data/{type}/{scenario}.json",
      "description": "Scenario-specific test data"
    },
    "report": {
      "type": "file",
      "format": "markdown",
      "mimeType": "text/markdown",
      "location": "output/reports/explorer-report-{scenario}.md",
      "description": "Exploration report with per-step results and fidelity summary"
    },
    "appContext": {
      "type": "file",
      "format": "markdown",
      "mimeType": "text/markdown",
      "location": "scenarios/app-contexts/{app}.md",
      "description": "Updated app-context with newly learned patterns"
    },
    "metrics": {
      "type": "file",
      "format": "json",
      "mimeType": "application/json",
      "location": "output/reports/metrics/explorer-metrics-{scenario}.json",
      "description": "Observability metrics (tokens, time, steps, skills used)"
    }
  },
  "skills": {
    "allSkills": {
      "web": ["web/navigate", "web/interact", "web/verify", "web/wait", "web/extract", "web/scroll", "web/frame", "web/file-transfer", "web/drag-drop", "web/dialog", "web/keyboard", "web/multi-tab", "web/network"],
      "api": ["api/request", "api/capture", "api/validate-schema"],
      "auth": ["auth/sso-login", "auth/basic-login", "auth/storage-state"],
      "data": ["data/load", "data/shared-data"],
      "mobile": ["mobile/navigate", "mobile/interact", "mobile/verify", "mobile/app-management", "mobile/android", "mobile/ios"],
      "a11y": ["a11y/axe-audit", "a11y/aria-check"]
    },
    "activationByType": {
      "web": ["web/*", "api/*", "auth/*", "data/*", "a11y/*"],
      "api": ["api/*", "data/*"],
      "hybrid": ["web/*", "api/*", "auth/*", "data/*", "a11y/*"],
      "mobile": ["mobile/*", "auth/*", "data/*"],
      "mobile-hybrid": ["mobile/*", "api/*", "auth/*", "data/*"]
    },
    "note": "web type includes api/* for network interception and ad-hoc API calls during UI flows"
  },
  "security": {
    "requiredEnvVars": ["BASE_URL", "TEST_USERNAME", "TEST_PASSWORD"],
    "optionalEnvVars": ["SSO_EMAIL", "SSO_PASSWORD", "API_BASE_URL", "API_TOKEN"],
    "requiresMcp": true,
    "mcpServers": ["playwright"],
    "note": "App credentials are read from .env via process.env — NEVER hardcoded"
  },
  "dependencies": {
    "playwright": ">=1.50.0",
    "playwright-mcp": "required for web/hybrid scenarios",
    "appium-mcp": "required for mobile scenarios"
  },
  "platforms": ["windows", "linux", "macos"],
  "maxSubagentDepth": 5,
  "examples": [
    "Explore scenarios/web/saucedemo-login.md and generate test code",
    "Run Explorer-Builder on scenarios/hybrid/checkout-flow.md with folder=saucedemo",
    "Generate tests for scenarios/api/petstore-crud.md (no browser needed)"
  ]
}
