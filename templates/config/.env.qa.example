# Per-environment template — QA
#
# How to use:
#   1. cp templates/config/.env.qa.example output/.env.qa
#   2. Edit output/.env.qa with your QA environment values
#   3. Run tests with: TEST_ENV=qa npx playwright test
#
# output/.env.qa is gitignored — real secrets never leak. For CI/CD, inject
# secrets via your vault / CI secret store instead of committing values here.
# See README.md "Secrets Management — Vault / CI Secret Store" for details.
#
# IMPORTANT: If any value contains # or special characters, wrap it in double quotes.
# Example: TEST_PASSWORD="my#secret!pass"
# Unquoted # silently truncates the value (dotenv behavior).

# Application Under Test
BASE_URL=https://qa.your-app-url.com
TEST_USERNAME=
TEST_PASSWORD=""

# SSO / OAuth (if applicable)
SSO_EMAIL=
SSO_PASSWORD=""

# API Testing
API_BASE_URL=https://qa.your-api-url.com
API_TOKEN=
API_USERNAME=
API_PASSWORD=""

# Framework Settings
HEADLESS=true
DEFAULT_TIMEOUT=30000
NAVIGATION_TIMEOUT=60000
# Explorer browser viewport is set in .vscode/mcp.json → servers.playwright.args → --viewport-size
# (not configurable here). Keep that value aligned with projects[].use.viewport in playwright.config.ts.

# --- Mobile (Appium) ──────────────────────────────────────────────────────────
# Leave blank if you are not running mobile scenarios.
PLATFORM=                                   # android | ios
APPIUM_HOST=localhost
APPIUM_PORT=4723
NO_RESET=true                               # true = attach to installed app (fast); false = fresh install

# Android
ANDROID_DEVICE=                             # adb serial from `adb devices`, or emulator name
APP_PACKAGE=                                # e.g. com.example.app    (pair with APP_ACTIVITY)
APP_ACTIVITY=                               # e.g. com.example.app.MainActivity
# APP_PATH=                                 # alternative: absolute path to .apk for fresh install each session

# iOS (macOS only)
IOS_DEVICE=                                 # simulator name or device name, e.g. "iPhone 15"
IOS_UDID=                                   # required for real devices
IOS_VERSION=                                # e.g. 17.0
IOS_BUNDLE_ID=                              # e.g. com.example.app     (pair with simulator/device)
# IOS_APP_PATH=                             # alternative: absolute path to .app for fresh install each session

# BrowserStack (cloud device farm — optional)
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=
BROWSERSTACK_APP_URL=                       # Android app URL (bs://...) from BrowserStack app upload
BROWSERSTACK_IOS_APP_URL=                   # iOS app URL (bs://...) from BrowserStack app upload
